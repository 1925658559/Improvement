<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Light-RPC 代码规范配置
    基于：阿里巴巴 Java 开发手册（嵩山版）
    适用：Day 20 之后强制执行
    注意：学习阶段 (Day 1-20) 仅作建议，不强制
-->

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="warning"/>
    <property name="fileExtensions" value="java, properties, xml"/>

    <!-- 排除目标目录 -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value="^[\\/]target[\\/].*$"/>
    </module>

    <!-- 文件长度检查 (单个文件不超过 2000 行) -->
    <module name="FileLength">
        <property name="max" value="2000"/>
    </module>

    <!-- 文件 Tab 字符检查 (禁止使用 Tab) -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <module name="TreeWalker">
        <!-- ================================================== -->
        <!-- 命名规范 (Naming Conventions) -->
        <!-- ================================================== -->

        <!-- 包名：全小写，点分隔 -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- 类名：大驼峰 (UpperCamelCase) -->
        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
        </module>

        <!-- 方法名：小驼峰 (lowerCamelCase) -->
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- 变量名：小驼峰 -->
        <module name="MemberName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- 参数名：小驼峰 -->
        <module name="ParameterName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- 常量名：全大写+下划线 -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
        </module>

        <!-- 禁止系列命名：避免 isBoolean, 应为 hasBoolean/shouldBoolean -->
        <module name="IllegalIdentifierName">
            <property name="tokens" value="VARIABLE_DEF,PARAMETER_DEF"/>
        </module>

        <!-- ================================================== -->
        <!-- 代码风格 (Coding Style) -->
        <!-- ================================================== -->

        <!-- 缩进：4 空格 -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="braceAdjustment" value="0"/>
            <property name="caseIndent" value="4"/>
            <property name="throwsIndent" value="4"/>
            <property name="lineWrappingIndentation" value="4"/>
            <property name="arrayInitIndent" value="4"/>
        </module>

        <!-- 大括号：左大括号不换行 -->
        <module name="LeftCurly">
            <property name="option" value="eol"/>
        </module>
        <module name="RightCurly">
            <property name="option" value="same"/>
        </module>

        <!-- 单行最大长度：120 字符 -->
        <module name="LineLength">
            <property name="max" value="120"/>
            <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
        </module>

        <!-- 方法长度：不超过 80 行 -->
        <module name="MethodLength">
            <property name="max" value="80"/>
            <property name="countEmpty" value="false"/>
        </module>

        <!-- ================================================== -->
        <!-- 导入规范 (Imports) -->
        <!-- ================================================== -->

        <!-- 避免星号导入 -->
        <module name="AvoidStarImport"/>
        <module name="UnusedImports"/>
        <module name="RedundantImport"/>
        <module name="IllegalImport"/>
        <module name="ImportOrder">
            <property name="groups" value="java,javax,org,com"/>
            <property name="ordered" value="true"/>
            <property name="separated" value="true"/>
            <property name="option" value="bottom"/>
        </module>

        <!-- ================================================== -->
        <!-- 空白规范 (Whitespace) -->
        <!-- ================================================== -->

        <module name="WhitespaceAround">
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
            <property name="allowEmptyTypes" value="true"/>
            <property name="allowEmptyLoops" value="true"/>
            <property name="tokens" value="
                ASSIGN, BAND, BAND_ASSIGN, BOR, BOR_ASSIGN, BSR, BSR_ASSIGN,
                BXOR, BXOR_ASSIGN, COLON, DIV, DIV_ASSIGN, EQUAL, GE, GT, LAND,
                LCURLY, LE, LITERAL_ASSERT, LITERAL_CATCH, LITERAL_DO, LITERAL_ELSE,
                LITERAL_FINALLY, LITERAL_FOR, LITERAL_IF, LITERAL_RETURN, LITERAL_SWITCH,
                LITERAL_SYNCHRONIZED, LITERAL_TRY, LITERAL_WHILE, LOR, LT, MINUS,
                MINUS_ASSIGN, MOD, MOD_ASSIGN, NOT_EQUAL, PLUS, PLUS_ASSIGN, QUESTION,
                RCURLY, SL, SLIST, SL_ASSIGN, SR, SR_ASSIGN, STAR, STAR_ASSIGN,
                TYPE_EXTENSION_AND, LITERAL_INSTANCEOF"/>
        </module>

        <module name="WhitespaceAfter">
            <property name="tokens" value="COMMA, SEMI, TYPECAST, LITERAL_IF, LITERAL_ELSE,
                LITERAL_WHILE, LITERAL_DO, LITERAL_FOR, DO_WHILE"/>
        </module>

        <!-- ================================================== -->
        <!-- 最佳实践 (Best Practices) -->
        <!-- ================================================== -->

        <!-- 禁止 System.out.println -->
        <module name="Regexp">
            <property name="format" value="System\.out\.println"/>
            <property name="illegalPattern" value="true"/>
            <property name="message" value="禁止使用 System.out.println，请使用日志框架 (SLF4J)"/>
        </module>

        <!-- 禁止 e.printStackTrace() -->
        <module name="Regexp">
            <property name="format" value="\.printStackTrace\(\)"/>
            <property name="illegalPattern" value="true"/>
            <property name="message" value="禁止使用 printStackTrace()，请使用日志框架"/>
        </module>

        <!-- 禁止硬编码魔法值 (部分检测) -->
        <module name="MagicNumber">
            <property name="ignoreNumbers" value="-1, 0, 1, 2"/>
            <property name="ignoreHashCodeMethod" value="true"/>
            <property name="ignoreAnnotation" value="true"/>
            <property name="ignoreFieldDeclaration" value="true"/>
        </module>

        <!-- 禁止使用原生 Hashtable/Vector -->
        <module name="IllegalImport">
            <property name="illegalPkgs" value="java.util.Hashtable, java.util.Vector"/>
        </module>

        <!-- ================================================== -->
        <!-- OOP 规范 (Object-Oriented Programming) -->
        <!-- ================================================== -->

        <!-- 避免深层嵌套 (不超过 3 层) -->
        <module name="NestedIfDepth">
            <property name="max" value="3"/>
        </module>
        <module name="NestedForDepth">
            <property name="max" value="2"/>
        </module>

        <!-- 复杂度检查 (圈复杂度不超过 10) -->
        <module name="CyclomaticComplexity">
            <property name="max" value="10"/>
        </module>

        <!-- 设计检查：禁止直接访问类型 -->
        <module name="HideUtilityClassConstructor"/>
        <module name="InterfaceIsType"/>
        <module name="VisibilityModifier">
            <property name="packageAllowed" value="true"/>
            <property name="protectedAllowed" value="true"/>
        </module>

        <!-- ================================================== -->
        <!-- 注释规范 (Comments) -->
        <!-- ================================================== -->

        <!-- 类注释 -->
        <module name="MissingJavadocType">
            <property name="scope" value="public"/>
        </module>

        <!-- 方法注释 (public 方法) -->
        <module name="MissingJavadocMethod">
            <property name="scope" value="public"/>
            <property name="allowMissingPropertyJavadoc" value="true"/>
        </module>

        <!-- TODO/FIXME 必须标注负责人 -->
        <module name="CommentsIndentation"/>
        <module name="RegexpSinglelineJava">
            <property name="format" value="\/\/\s*(TODO|FIXME)\s*"/>
            <property name="message" value="TODO/FIXME 必须标注负责人: // FIXME(xxx) reason"/>
        </module>

        <!-- ================================================== -->
        <!-- 并发规范 (Concurrency) -->
        <!-- ================================================== -->

        <!-- 禁止显式创建 Thread -->
        <module name="Regexp">
            <property name="format" value="new Thread\("/>
            <property name="illegalPattern" value="true"/>
            <property name="message" value="禁止显式创建 Thread，请使用线程池"/>
        </module>

        <!-- 禁止非线程安全类在并发场景使用 (部分检测) -->
        <module name="Regexp">
            <property name="format" value="SimpleDateFormat"/>
            <property name="illegalPattern" value="true"/>
            <property name="message" value="SimpleDateFormat 非线程安全，请使用 DateTimeFormatter 或 ThreadLocal"/>
        </module>

    </module>
</module>
